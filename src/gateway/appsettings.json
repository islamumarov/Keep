{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": {
          "Path": "/api/auth/{**catch-all}"
        }
      },
      "todo-route": {
        "ClusterId": "todo-cluster",
        "Match": {
          "Path": "/api/todos/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth1": {
            "Address": "http://localhost:5050"
          }
        }
      },
      "todo-cluster": {
        "Destinations": {
          "todo1": { "Address": "http://localhost:5002" }
        }
      }
    }
  }
}




