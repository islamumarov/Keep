{
  "ReverseProxy": {
    "Routes": {
      "auth-route": {
        "ClusterId": "auth-cluster",
        "Match": { "Path": "/api/auth/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api/auth" } ]
      },
      "todo-route": {
        "ClusterId": "todo-cluster",
        "Match": { "Path": "/api/todos/{**catch-all}" },
        "Transforms": [ { "PathRemovePrefix": "/api/todos" } ]
      }
    },
    "Clusters": {
      "auth-cluster": {
        "Destinations": {
          "auth1": { "Address": "http://localhost:5001" }
        }
      },
      "todo-cluster": {
        "Destinations": {
          "todo1": { "Address": "http://localhost:5002" }
        }
      }
    }
  }
}




